# Connection string format: postgresql:// scheme (canonical), not postgres://
# Mac dev: peteryakovlev@localhost:5432/kalshi_pipeline (Postgres.app, trust auth)
# Server prod: kalshi:<password>@localhost:5432/kalshi_pipeline (md5 auth)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/kalshi_pipeline

# ENV controls structlog renderer:
# - dev (default): structlog.dev.ConsoleRenderer (colored, key-value)
# - any other value (prod): structlog.processors.JSONRenderer
ENV=dev
